# Cluo Staging Environment
# Generated by Ansible — do not edit manually

# Image registry (used by docker-compose to pull cluo images)
CLUO_REGISTRY={{ cluo_registry }}
CLUO_STAGING_TAG={{ cluo_staging_tag }}

# Runtime
CLUO_ENVIRONMENT=staging
CLUO_SERVER_HOST=0.0.0.0
CLUO_SERVER_PORT=8080
CLUO_SERVER_READ_TIMEOUT=15s
CLUO_SERVER_WRITE_TIMEOUT=15s
CLUO_SERVER_IDLE_TIMEOUT=60s
CLUO_SERVER_SHUTDOWN_TIMEOUT=30s

# Database (connects to production postgres container with separate database)
CLUO_DB_HOST=cluo-prod-postgres
CLUO_DB_PORT=5432
CLUO_DB_NAME={{ cluo_staging_db_name }}
CLUO_DB_USER={{ cluo_staging_db_user }}
CLUO_DB_PASSWORD={{ cluo_staging_db_password }}
CLUO_DB_SSL_MODE=disable
CLUO_DB_MAX_OPEN_CONNS=10
CLUO_DB_MAX_IDLE_CONNS=3
CLUO_DB_CONN_MAX_LIFETIME=5m
CLUO_DB_CONN_MAX_IDLE_TIME=1m

# Redis (connects to production redis container with separate DB index)
CLUO_REDIS_HOST=cluo-prod-redis
CLUO_REDIS_PORT=6379
CLUO_REDIS_PASSWORD=
CLUO_REDIS_DB=1

# HashiCorp Vault (connects to homelab-vault container)
VAULT_ADDR=http://homelab-vault:8200
VAULT_TOKEN={{ vault_root_token | default('') }}
CLUO_VAULT_MOUNT_PATH=secret
CLUO_VAULT_TRANSIT_MOUNT_PATH=transit
CLUO_VAULT_KEY_NAME=cluo-staging
CLUO_VAULT_PEPPER_PATH=secret/cluo/staging/pepper

# Logging (verbose for staging)
CLUO_LOG_LEVEL=debug
CLUO_LOG_STYLE=json

# Metrics
CLUO_METRICS_ENABLED=true
CLUO_METRICS_PATH=/metrics

# Tracing
CLUO_TRACING_ENABLED=false
CLUO_TRACING_SAMPLER=1.0

# Service identification
CLUO_SERVICE_NAME=cluo-api-staging
CLUO_SERVICE_VERSION=0.1.0

# CORS allowed origins (comma-separated list)
# "wails://wails" is required for Wails desktop production builds
CLUO_CORS_ORIGIN=wails://wails

# SvelteKit frontend: public API URL consumed by web and mobile apps at runtime
PUBLIC_API_URL=https://staging-api.{{ cluo_domain }}

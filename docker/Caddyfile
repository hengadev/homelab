media.{$CLUO_DOMAIN} {
    reverse_proxy homelab-minio:9000 {
        # Preserve the original Host header so MinIO can validate presigned URL signatures
        header_up Host {host}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
    }
}

{$DOMAIN} {
    reverse_proxy portfolio:3000
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }
}

links.{$DOMAIN} {
    # Only rewrite the bare root request so asset requests (JS/CSS/images)
    # pass through untouched to the same portfolio backend.
    @root path /
    rewrite @root /links?{query}

    reverse_proxy portfolio:3000
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }
}


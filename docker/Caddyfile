    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
    }
}

anki-api.{$DOMAIN} {
    reverse_proxy anki-api:8000
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
    }
}

vault.{$DOMAIN} {
    # WebSocket endpoint for real-time sync (CRITICAL)
    reverse_proxy /notifications/hub vaultwarden:3012
    reverse_proxy vaultwarden:80
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy no-referrer
    }
}

nomi.{$DOMAIN} {
    # Same /api/* split the SvelteKit dev server's vite proxy does locally —
    # same-origin paths, no CORS, no separate api.* hostname.
    reverse_proxy /api/* nomi-api:8080
    reverse_proxy nomi-web:3000
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
    }
}


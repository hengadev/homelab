# Hetzner Cloud API Token
# Generate at: https://console.hetzner.cloud/security/tokens
HCLOUD_TOKEN=

# Cloudflare API Token (for homelab domain henga.dev)
# Scoped to: Zone:DNS:Edit + Zone:Zone:Read
# Generate at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID
# Found in your domain's DNS settings page
CLOUDFLARE_ZONE_ID=

# Domain name (without subdomain)
DOMAIN=example.com

# =============================================================================
# Cluo app domain
# =============================================================================

# Cloudflare API Token (for Cluo app domain clientvault.fr)
# Scoped to: Zone:DNS:Edit + Zone:Zone:Read for clientvault.fr only
# Generate at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_CLUO_API_TOKEN=

# Cloudflare Zone ID for Cluo app domain (e.g., clientvault.fr)
# Found in your domain's DNS settings page
CLOUDFLARE_CLUO_ZONE_ID=

# Cluo app domain name (without subdomain)
CLUO_DOMAIN=clientvault.fr

# SSH Public Key (full key string, starts with ssh-rsa/ssh-ed25519)
SSH_PUBLIC_KEY=

# Local path to SSH private key
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Vaultwarden Admin Token
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=

# Admin email for Let's Encrypt notifications
ADMIN_EMAIL=admin@example.com

# AWS - Local use (Terraform runs on your machine and uses your AWS CLI profile)
# The profile must have permissions to create S3 buckets and IAM users.
AWS_PROFILE=your-profile-name
AWS_DEFAULT_REGION=us-east-1

# AWS - Backup container credentials (scoped IAM user, generated by 'make init')
# After running make init, retrieve with:
#   terraform -chdir=terraform output backup_iam_access_key_id
#   terraform -chdir=terraform output -raw backup_iam_secret_access_key
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=

# Bucket name only — no s3:// prefix. Must be globally unique across all AWS accounts.
BACKUP_S3_BUCKET=homelab-backups-yourname

# Backup encryption passphrase (for symmetric GPG encryption)
BACKUP_PASSPHRASE=

# GitHub username (for portfolio image reference)
GITHUB_USERNAME=

# =============================================================================
# Anki sync server
# =============================================================================

# Credentials for the Anki sync server — used by Anki desktop/mobile clients
# Format: plain username and password (combined as user:pass by Ansible)
ANKI_USERNAME=
ANKI_PASSWORD=

# =============================================================================
# Cluo app
# =============================================================================

# Docker image registry prefix (e.g. dockerhub username or ghcr.io/youruser)
CLUO_REGISTRY=garyhy

# Image tags to deploy — prod and staging are intentionally separate
CLUO_PROD_TAG=latest
CLUO_STAGING_TAG=staging

# Production database credentials
CLUO_PROD_DB_NAME=cluo_prod
CLUO_PROD_DB_USER=cluo
CLUO_PROD_DB_PASSWORD=

# Staging database credentials
CLUO_STAGING_DB_NAME=cluo_staging
CLUO_STAGING_DB_USER=cluo
CLUO_STAGING_DB_PASSWORD=

# MinIO backup credentials (cluo-minio-backup-staging-user, scoped IAM user,
# generated by 'terraform apply' in this repo's terraform/ — cluo's own
# Terraform is an unprovisioned future-deployment blueprint, not what's live,
# so this credential is managed here alongside the rest of this server).
# After applying, retrieve with:
#   terraform -chdir=terraform output cluo_minio_backup_iam_access_key_id
#   terraform -chdir=terraform output -raw cluo_minio_backup_iam_secret_access_key
CLUO_BACKUP_AWS_ACCESS_KEY_ID=
CLUO_BACKUP_AWS_SECRET_ACCESS_KEY=
CLUO_BACKUP_AWS_REGION=us-east-1

# Bucket name only — no s3:// prefix.
CLUO_BACKUP_S3_BUCKET=cluo-minio-backups-staging

# Backup encryption passphrase (for symmetric GPG encryption, separate from BACKUP_PASSPHRASE above)
CLUO_BACKUP_PASSPHRASE=
